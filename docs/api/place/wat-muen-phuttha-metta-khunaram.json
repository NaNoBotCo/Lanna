%94%E0%B8%AB%E0%B8%A1%E0%B8%B7%E0%B9%88%E0%B8%99%E0%B8%9E%E0%B8%B8%E0%B8%97%E0%B8%98%E0%B9%80%E0%B8%A1%E0%B8%95%E0%B8%95%E0%B8%B2%E0%B8%84%E0%B8%B8%E0%B8%93%E0%B8%B2%E0%B8%A3%E0%B8%B2%E0%B8%A1_Wat_Muen_Buddha_Mettakhunaram_Chiang_Rai_%28October_2021%29_-_img_02.jpg", "author": "Chainwit.", "license": "CC BY-SA 4.0", "licenseUrl": "https://creativecommons.org/licenses/by-sa/4.0", "source": "https://commons.wikimedia.org/wiki/File:%E0%B8%A7%E0%B8%B1%E0%B8%94%E0%B8%AB%E0%B8%A1%E0%B8%B7%E0%B9%88%E0%B8%99%E0%B8%9E%E0%B8%B8%E0%B8%97%E0%B8%98%E0%B9%80%E0%B8%A1%E0%B8%95%E0%B8%95%E0%B8%B2%E0%B8%84%E0%B8%B8%E0%B8%93%E0%B8%B2%E0%B8%A3%E0%B8%B2%E0%B8%A1_Wat_Muen_Buddha_Mettakhunaram_Chiang_Rai_(October_2021)_-_img_02.jpg"}], "sources": [{"type": "wikidata", "ref": "Q13020889"}], "article": {"th": {"lang": "th", "title": "วัดหมื่นพุทธเมตตาคุณาราม", "url": "https://th.wikipedia.org/wiki/%E0%B8%A7%E0%B8%B1%E0%B8%94%E0%B8%AB%E0%B8%A1%E0%B8%B7%E0%B9%88%E0%B8%99%E0%B8%9E%E0%B8%B8%E0%B8%97%E0%B8%98%E0%B9%80%E0%B8%A1%E0%B8%95%E0%B8%95%E0%B8%B2%E0%B8%84%E0%B8%B8%E0%B8%93%E0%B8%B2%E0%B8%A3%E0%B8%B2%E0%B8%A1", "license": "CC BY-SA 4.0", "licenseUrl": "https://creativecommons.org/licenses/by-sa/4.0/", "text": "วัดหมื่นพุทธเมตตาคุณาราม (敕赐万佛慈恩寺-敕賜萬佛慈恩寺) เป็นวัดมหายาน สังกัดคณะสงฆ์จีนนิกายแห่งประเทศไทย ตั้งอยู่ที่ บ้านป่าไร่ ตำบลท่าข้าวเปลือก (ถนนสายกิ่วพร้าว-บ้านปงน้อย) อำเภอแม่จัน จังหวัดเชียงราย", "sections": [{"heading": "ประวัติ", "kind": "history", "text": "เมื่อปี พ.ศ. 2532 ทางวัดนำโดยพระมหาคณาจารย์จีนธรรมสมาธิวัตร (เย็นเต็ก) ได้จัดซื้อที่ดินบริเวณบ้านป่าไร่ ตำบลท่าข้าวเปลือก อำเภอแม่จัน จังหวัดเชียงราย เพื่อก่อสร้างวัดจีนนิกายแห่งใหม่ขึ้นโดยตั้งชื่อว่า \"วัดหมื่นพุทธเมตตาคุณาราม\" โดยมีการวางศิลาฤกษ์ธรรมศาลาเฉลิมพระเกียรติสมเด็จย่าในปี พ.ศ. 2536 และก่อสร้างศาลากตัญญูอนุสรณ์พระมหาคณาจารย์จีนธรรมสมาธิวัตร (โพธิ์แจ้ง) เมื่อปี พ.ศ. 2537 และได้น้อมศรัทธาสร้างวัดเพื่อถวายเป็นพระราชกุศลเมื่อครั้งพระบาทสมเด็จพระเจ้าอยู่หัวทรงครองสิริราชสมบัติครบ 50 ปี โดยมุ่งการเผยแผ่พุทธศาสนาฝ่ายมหายานและส่งเสริมการศึกษาให้แก่ชาวไทยภูเขาในพื้นที่ภาคเหนือ"}, {"heading": "สิ่งก่อสร้างภายในวัด", "kind": null, "text": "พระอวโลกิเตศวรโพธิสัตว์ หรือ พระสหัสสหัตถสหัสสเนตร (พันมือพันตา) ซึ่งใช้ไม้แดงแกะสลักจากประเทศจีน มีความสูง 6.50 เมตร กว้าง 3.19 เมตร สี่หน้ารวมพันมือพันตา\nพระศรีอริยเมตไตรย องค์ใหญ่ที่สุดในโลก เมื่อลงจากสนามบินเชียงราย ขับรถมาทางแม่จันจะเห็นเด่นชัดตั้งตระหง่านอยู่"}, {"heading": "การเดินทาง", "kind": null, "text": "ไปตามถนนเชียงราย-แม่สาย จนถึงทางแยกเข้าเชียงแสน เลี้ยวขวา ไปตามถนนเชียงแสนประมาณ 20 กิโลเมตร (เลยพิพิธภัณฑ์พระไปประมาณ 4 กิโลเมตร) เลี้ยวขวาอีกครั้งตรงสะพานท่าข้าวเปลือก ขับเข้าไปตามถนนสายกิ่วพร้าว-บ้านปงน้อย อีกประมาณ 11 กิโลเมตร จะเห็นวัดอยู่ด้านขวามือ"}], "chars": 1375}}, "kind": "wat", "facets": {"kind": ["wat"], "province": ["Chiang Rai"], "hasPhotograph": [true], "describes": ["history"], "articleLanguages": ["th"], "confidence": ["crawled"]}, "url": "https://wichaa.net/place/wat-muen-phuttha-metta-khunaram/"}
  "endpoints": [
    {
      "path": "/api/activity.json",
      "url": "https://wichaa.net/api/activity.json",
      "description": "Snapshot of recent pipeline activity as of build time.",
      "format": "application/json",
      "templated": false
    },
    {
      "path": "/api/articles.json",
      "url": "https://wichaa.net/api/articles.json",
      "description": "Index of synthesised subject articles (genre/entity/subgenre).",

      "format": "application/json",
      "templated": false
    },
    {
      "path": "/api/coverage.json",
      "url": "https://wichaa.net/api/coverage.json",
      "description": "What has been looked for, where, by what method — so an absence can be read. Distinguishes out-of-scope from not-in-the-source from simply unwritten, which need three different responses.",
      "format": "application/json",
      "templated": false
    },
    {
      "path": "/api/dashboard.json",
      "url": "https://wichaa.net/api/dashboard.json",
